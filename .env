# =============================================================================
# Environment Variables
# =============================================================================
#
# USAGE:
#   - Copy this file to .env.local for local development overrides
#   - Never commit real secrets to version control
#   - Variables prefixed with NEXT_PUBLIC_ are exposed to the browser bundle;
#     all others are server-side only
#
# FILES (Next.js load order, later files take precedence):
#   .env              → Shared defaults, safe to commit (no secrets)
#   .env.local        → Local overrides, gitignored
#   .env.development  → Dev environment only
#   .env.production   → Production environment only
# =============================================================================


# -----------------------------------------------------------------------------
# API — Base URLs
# -----------------------------------------------------------------------------

# External API base URL — the upstream backend this server communicates with.
# Used server-side only (no NEXT_PUBLIC_ prefix).
# Example: https://api.your-domain.com/
API_BASE_URL= https://api.your-domain.com/

# Internal Next.js proxy route for public (unauthenticated) endpoints.
# Requests from the browser are sent here and forwarded to API_BASE_URL by proxy.ts.
# Pattern: /api/public/v1/<environment>
API_BASE_URL_PUBLIC=/public/v1

# Internal Next.js proxy route for private (authenticated) endpoints.
# Requires a valid session — the proxy layer should validate auth before forwarding.
# Pattern: /api/private/v1/<environment>
API_BASE_URL_PRIVATE=/private/v1


# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# HMAC_KEY — used to sign and verify request payloads or tokens.
# Must be a cryptographically random string (recommended: 64+ hex characters).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# HMAC_KEY=

# Placeholders to prevent "Variable not set" errors
# Replace these with actual secure values in .env.local and never commit real secrets.
HMAC_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef # Sample Key
ENCRYPTION_SECRET=0123456789abcdef0123456789abcdef # Sample Key

